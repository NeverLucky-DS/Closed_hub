# =============================================================================
# Closed Hub — переменные окружения
# Скопируй в .env:  cp .env.example .env
# Не коммить .env (секреты).
# =============================================================================

# --- Telegram (обязательно) ---
# Токен от @BotFather
TELEGRAM_BOT_TOKEN=

# Супергруппа с включёнными темами (форум):
#   • Числовой id: -1001234567890 (узнать через бота @getidsbot / RawDataBot в чате)
#   • Или @username группы, если он публичный (пример: @ML_hub_private)
TELEGRAM_GROUP_CHAT_ID=

# Темы форума — последнее число в ссылке t.me/c/…/<id темы>
# Новости (сюда бот публикует мероприятия)
TELEGRAM_TOPIC_NEWS=4
# Обсуждения (зарезервировано под будущие фичи)
TELEGRAM_TOPIC_DISCUSSION=3
# Рейтинг: сюда бот шлёт все начисления очков (кто / за что / сколько)
TELEGRAM_TOPIC_RATING=2

# Куда пересылать сообщения из лички (нативный forward, виден отправитель).
# Пусто = та же тема, что TELEGRAM_TOPIC_NEWS
TELEGRAM_TOPIC_ML_FORWARD=

# Лимиты для пересылок в ленту (анти-спам)
ML_FORWARD_MAX_AGE_DAYS=21
ML_FORWARD_DAILY_CAP=20

# Опционально: явный id темы для мероприятий; если пусто — используется TELEGRAM_TOPIC_NEWS
TELEGRAM_EVENTS_TOPIC_ID=

# Кого при старте занести в белый список (могут приглашать), через запятую
INITIAL_WHITELIST_TELEGRAM_IDS=

# --- Mistral (обязательно для ИИ) ---
MISTRAL_API_KEY=

# Дешёвая модель для маршрутизации сообщений
MISTRAL_MODEL_ROUTING=mistral-small-latest
# Модель для дедупа мероприятий, HR, описания файлов
MISTRAL_MODEL_DEFAULT=mistral-small-latest

# --- Groq (опционально: распознавание голосовых) ---
# https://console.groq.com — Whisper через API
GROQ_API_KEY=

# --- Google Sheets (опционально: выгрузка подтверждённых HR) ---
# Как подключить:
# 1) Google Cloud Console → проект → APIs & Services → Enable "Google Sheets API".
# 2) IAM → Service Accounts → Create; Keys → Add key → JSON → сохрани файл (секрет).
# 3) В JSON есть client_email — открой свою таблицу в Google Sheets → Поделиться →
#    дай этому email право «Редактор».
# 4) Создай пустую таблицу; ID из URL: https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
# 5) Укажи путь к JSON и ID ниже (имя переменной именно GOOGLE_SHEET_ID).
#    Для каждой компании создаётся отдельный лист с названием компании; строки HR пишутся с колонки E.
GOOGLE_SHEET_ID=
# Путь к JSON на твоей машине при запуске через uv run python (не Docker):
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./closeml-fc7387cd4ce5.json
# Только для docker compose: какой файл на хосте примонтировать в контейнер (имя может быть любым).
# Внутри контейнера путь фиксирован в compose: /app/secrets/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON_HOST=./closeml-fc7387cd4ce5.json

# --- PostgreSQL ---
# Локальный запуск бота (uv run): localhost.
# docker compose up: для сервиса bot URL переопределён в docker-compose.yml на хост postgres.
DATABASE_URL=postgresql://closedhub:closedhub@localhost:5432/closedhub

# --- Веб-хаб (отдельный процесс: uv run python -m web.main или сервис web в compose) ---
# С телефона в той же Wi‑Fi: оставь WEB_HOST=0.0.0.0, узнай URL — ./scripts/print-web-lan-url.sh
WEB_HOST=0.0.0.0
WEB_PORT=8000
# Секрет для подписи cookie сессии и HMAC одноразового кода входа (сгенерируй случайную строку).
WEB_SESSION_SECRET=
# Публичный URL сайта (для кнопки «Сайт» в боте), например https://hub.example.com
WEB_PUBLIC_BASE_URL=
# Срок жизни кода из Telegram (сек)
WEB_AUTH_CODE_TTL_SEC=600
# Лимит размера фото профиля (МБ)
WEB_MAX_PROFILE_PHOTO_MB=3
# Кто может на сайте удалять файлы и скрывать новости (Telegram user id, через запятую).
# Пустое значение WEB_ADMIN_TELEGRAM_IDS= отключает всех. Если строку не задавать — в коде есть дефолт.
WEB_ADMIN_TELEGRAM_IDS=1202549697

# --- Файлы ---
# Куда сохранять вложения (в контейнере обычно /app/storage)
FILE_STORAGE_PATH=./storage
MAX_PDF_SIZE_MB=20

# --- HR ---
# Пауза (сек) после последнего сообщения контекста перед вызовом Mistral
HR_CONTEXT_DEBOUNCE_SEC=45

# Легаси: кнопки категорий берутся из БД (file_categories). Строка не влияет на UI.
FILE_CATEGORIES=course,contest,notes,other
